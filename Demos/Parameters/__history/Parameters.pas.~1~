unit Unit4;

interface

uses
  Windows, Messages, SysUtils, Variants, Classes, Graphics, Controls, Forms,
  Dialogs, DelphiAnimations, ExtCtrls, Vcl.StdCtrls, DelphiFixes,
  Vcl.Samples.Spin;

type
  TForm4 = class(TForm)
    tmrAnimations: TTimer;
    Panel1: TPanel;
    Panel2: TPanel;
    Button1: TButton;
    lstProperty: TListBox;
    sedMovement: TSpinEdit;
    sedTime: TSpinEdit;
    procedure tmrAnimationsTimer(Sender: TObject);
    procedure Button1Click(Sender: TObject);
    procedure lstPropertyClick(Sender: TObject);
    procedure sedMovementChange(Sender: TObject);
    procedure sedTimeChange(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form4: TForm4;
  atAnimationType: TAnimationType;
  apAnimationProperty: TAnimationProperty;
  iMovement, iTime: Integer;

implementation

{$R *.dfm}

procedure TForm4.Button1Click(Sender: TObject);
begin
  AnimateControl(Panel2, atAnimationType, apAnimationProperty, iTime,
    ToInt(iMovement * Form4.FScaleFactor))
end;

procedure TForm4.lstPropertyClick(Sender: TObject);
begin
  apAnimationProperty := TAnimationProperty(lstProperty.ItemIndex);
end;

procedure TForm4.sedMovementChange(Sender: TObject);
begin
  iMovement := sedMovement.Value;
end;

procedure TForm4.sedTimeChange(Sender: TObject);
begin
  iTime := sedTime.Value;
end;

procedure TForm4.tmrAnimationsTimer(Sender: TObject);
begin
  AnimationTimer;
end;

end.
